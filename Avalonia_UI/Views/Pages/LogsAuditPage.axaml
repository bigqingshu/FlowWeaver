<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Avalonia_UI.ViewModels"
             x:Class="Avalonia_UI.Views.Pages.LogsAuditPage"
             x:DataType="vm:MainWindowViewModel">
    <Grid RowDefinitions="Auto,*"
          RowSpacing="12"
          Margin="12">
        <Border Classes="Card"
                Padding="14">
            <Grid RowDefinitions="Auto,Auto"
                  ColumnDefinitions="Auto,*,Auto,*,Auto,*,Auto,*,Auto,Auto"
                  RowSpacing="10"
                  ColumnSpacing="10">
                <TextBlock Text="{Binding WorkflowRunFilterText}"
                           VerticalAlignment="Center"
                           Foreground="#2F3742"/>
                <TextBox Grid.Column="1"
                         Text="{Binding LogWorkflowRunIdFilter}"
                         Watermark="{Binding RunIdWatermarkText}"/>
                <TextBlock Grid.Column="2"
                           Text="{Binding NodeRunFilterText}"
                           VerticalAlignment="Center"
                           Foreground="#2F3742"/>
                <TextBox Grid.Column="3"
                         Text="{Binding LogNodeRunIdFilter}"
                         Watermark="{Binding NodeRunIdWatermarkText}"/>
                <TextBlock Grid.Column="4"
                           Text="{Binding EventTypeFilterText}"
                           VerticalAlignment="Center"
                           Foreground="#2F3742"/>
                <TextBox Grid.Column="5"
                         Text="{Binding LogEventTypeFilter}"
                         Watermark="EVENT_TYPE"/>
                <TextBlock Grid.Column="6"
                           Text="{Binding AfterFilterText}"
                           VerticalAlignment="Center"
                           Foreground="#2F3742"/>
                <TextBox Grid.Column="7"
                         Text="{Binding RuntimeEventAfterSequenceNumberFilter}"
                         Watermark="{Binding SequenceWatermarkText}"/>
                <Button Grid.Column="8"
                        Content="{Binding RuntimeText}"
                        Command="{Binding RefreshRuntimeEventLogCommand}"
                        MinWidth="92"/>
                <Button Grid.Column="9"
                        Content="{Binding AuditText}"
                        Command="{Binding RefreshAuditEventsCommand}"
                        MinWidth="84"/>

                <TextBlock Grid.Row="1"
                           Text="{Binding LimitText}"
                           VerticalAlignment="Center"
                           Foreground="#2F3742"/>
                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Text="{Binding RuntimeEventLimitFilter}"
                         Watermark="100"/>
                <ProgressBar Grid.Row="1"
                             Grid.Column="8"
                             Grid.ColumnSpan="2"
                             Height="8"
                             VerticalAlignment="Center"
                             IsIndeterminate="True"
                             IsVisible="{Binding IsLogBusy}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              ColumnDefinitions="*,*"
              ColumnSpacing="16">
            <Border Background="White"
                    BorderBrush="#D9DEE5"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14">
                <Grid RowDefinitions="Auto,*,Auto" RowSpacing="10">
                    <TextBlock Text="{Binding RuntimeEventsSectionText}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#14171A"/>
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding RuntimeEventLogEntries}"
                             BorderBrush="#E1E5EA"
                             BorderThickness="1">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:RuntimeEventListItemViewModel"
                                          x:DataType="vm:RuntimeEventListItemViewModel">
                                <Grid ColumnDefinitions="Auto,*,Auto"
                                      RowDefinitions="Auto,Auto"
                                      ColumnSpacing="12"
                                      Margin="8">
                                    <TextBlock Text="{Binding SequenceText}"
                                               FontWeight="SemiBold"
                                               Foreground="#4B5563"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding EventType}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="#1F2933"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding TimestampText}"
                                               FontSize="12"
                                               Foreground="#697586"/>
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="1"
                                               Text="{Binding WorkflowRunText}"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="#697586"/>
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="2"
                                               Text="{Binding NodeRunText}"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="#697586"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Grid.Row="2" Spacing="4">
                        <TextBlock Text="{Binding RuntimeEventLogMessage}"
                                   Foreground="#344054"/>
                        <TextBlock Text="{Binding RuntimeEventLogErrorMessage}"
                                   TextWrapping="Wrap"
                                   Foreground="#B42318"
                                   IsVisible="{Binding HasRuntimeEventLogError}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Background="White"
                    BorderBrush="#D9DEE5"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14">
                <Grid RowDefinitions="Auto,*,Auto" RowSpacing="10">
                    <TextBlock Text="{Binding AuditEventsSectionText}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#14171A"/>
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding AuditEvents}"
                             BorderBrush="#E1E5EA"
                             BorderThickness="1">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:AuditEventListItemViewModel"
                                          x:DataType="vm:AuditEventListItemViewModel">
                                <Grid ColumnDefinitions="*,Auto"
                                      RowDefinitions="Auto,Auto,Auto"
                                      ColumnSpacing="12"
                                      Margin="8">
                                    <TextBlock Text="{Binding EventType}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="#1F2933"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Decision}"
                                               FontWeight="SemiBold"
                                               Foreground="#4B5563"/>
                                    <TextBlock Grid.Row="1"
                                               Text="{Binding AuditEventId}"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="#697586"/>
                                    <TextBlock Grid.Row="2"
                                               Text="{Binding WorkflowRunText}"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="#697586"/>
                                    <TextBlock Grid.Row="2"
                                               Grid.Column="1"
                                               Text="{Binding NodeRunText}"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="#697586"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Grid.Row="2" Spacing="4">
                        <TextBlock Text="{Binding AuditEventLogMessage}"
                                   Foreground="#344054"/>
                        <TextBlock Text="{Binding AuditEventLogErrorMessage}"
                                   TextWrapping="Wrap"
                                   Foreground="#B42318"
                                   IsVisible="{Binding HasAuditEventLogError}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
