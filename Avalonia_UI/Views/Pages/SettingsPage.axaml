<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Avalonia_UI.ViewModels"
             xmlns:settings="using:Avalonia_UI.Views.Components.Settings"
             x:Class="Avalonia_UI.Views.Pages.SettingsPage"
             x:DataType="vm:MainWindowViewModel">
    <ScrollViewer>
        <StackPanel Spacing="16" Margin="24" MaxWidth="800" HorizontalAlignment="Center">
            <settings:LanguageSettingsView />
            <settings:ConnectionConfigView />
            <settings:StreamConfigView />
        </StackPanel>
    </ScrollViewer>
</UserControl>
