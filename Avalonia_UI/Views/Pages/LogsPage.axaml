<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Avalonia_UI.ViewModels"
             xmlns:logs="using:Avalonia_UI.Views.Components.Logs"
             x:Class="Avalonia_UI.Views.Pages.LogsPage"
             x:DataType="vm:MainWindowViewModel">
    <Grid RowDefinitions="Auto,*"
          RowSpacing="12"
          Margin="12">
        <logs:LogFilterBarView />
        <logs:RuntimeEventListView Grid.Row="1" />
    </Grid>
</UserControl>
