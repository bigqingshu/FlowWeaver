<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Avalonia_UI.ViewModels"
             xmlns:data="using:Avalonia_UI.Views.Components.Data"
             x:Class="Avalonia_UI.Views.Pages.DataPage"
             x:DataType="vm:MainWindowViewModel">
    <Grid ColumnDefinitions="1.05*,1.2*"
          ColumnSpacing="16"
          Margin="12">
        <data:TableRefListView Grid.Column="0" />
        <data:SharedPublicationListView Grid.Column="1" />
    </Grid>
</UserControl>
