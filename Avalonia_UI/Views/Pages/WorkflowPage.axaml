<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Avalonia_UI.ViewModels"
             xmlns:workflow="using:Avalonia_UI.Views.Components.Workflow"
             x:Class="Avalonia_UI.Views.Pages.WorkflowPage"
             x:DataType="vm:MainWindowViewModel">
    <Grid ColumnDefinitions="340,*,340"
          RowDefinitions="*,Auto"
          ColumnSpacing="16"
          RowSpacing="16"
          Margin="12">
        <workflow:WorkflowListView Grid.Column="0"
                                   Grid.RowSpan="2" />
        <workflow:WorkflowSummaryView Grid.Column="1" />
        <workflow:WorkflowNodeListView Grid.Column="2" />
        <workflow:WorkflowDataPreviewView Grid.Row="1"
                                          Grid.Column="1"
                                          Grid.ColumnSpan="2" />
    </Grid>
</UserControl>
