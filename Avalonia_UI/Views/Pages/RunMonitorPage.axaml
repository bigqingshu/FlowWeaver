<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Avalonia_UI.ViewModels"
             xmlns:rm="using:Avalonia_UI.Views.Components.RunMonitor"
             x:Class="Avalonia_UI.Views.Pages.RunMonitorPage"
             x:DataType="vm:MainWindowViewModel">
    <Grid ColumnDefinitions="340, 1.3*, 1*" ColumnSpacing="16" Margin="12">
        <rm:RunListView Grid.Column="0" />
        <rm:NodeRunListView Grid.Column="1" />
        <rm:RunDetailPanelView Grid.Column="2" />
    </Grid>
</UserControl>
