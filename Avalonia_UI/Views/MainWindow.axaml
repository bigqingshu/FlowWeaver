<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Avalonia_UI.ViewModels"
        xmlns:pages="using:Avalonia_UI.Views.Pages"
        xmlns:components="using:Avalonia_UI.Views.Components"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="760"
        x:Class="Avalonia_UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="FlowWeaver"
        Width="1100"
        Height="760"
        MinWidth="900"
        MinHeight="600"
        Background="#F8FAFC">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <!-- Base Button Styling -->
        <Style Selector="Button">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#F1F5F9" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="Foreground" Value="#334155" />
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="RenderTransform" Value="translateY(-1px)"/>
        </Style>
        <Style Selector="Button:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#E2E8F0" />
            <Setter Property="Foreground" Value="#334155" />
        </Style>
        <Style Selector="Button:pressed">
            <Setter Property="RenderTransform" Value="scale(0.97)"/>
        </Style>

        <!-- Primary Button Styling -->
        <Style Selector="Button.Primary">
            <Setter Property="Background" Value="#4F46E5"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.Primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#4338CA"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>
        <Style Selector="Button.Primary:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#3730A3"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>

        <!-- ListBoxItem Animations -->
        <Style Selector="ListBoxItem">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="4,4"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="ListBoxItem:pointerover">
            <Setter Property="RenderTransform" Value="translateX(2px)"/>
            <Setter Property="Background" Value="#F1F5F9"/>
        </Style>
        <Style Selector="ListBoxItem:selected">
            <Setter Property="Background" Value="#E2E8F0"/>
        </Style>

        <!-- TabControl as Side Navigation -->
        <Style Selector="TabControl">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="TabControl[TabStripPlacement=Left] /template/ ContentPresenter#PART_SelectedContentHost">
            <Setter Property="Padding" Value="24,0,0,0"/>
        </Style>
        <Style Selector="TabControl[TabStripPlacement=Left] /template/ ItemsPresenter#PART_ItemsPresenter">
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style Selector="TabItem">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="MinHeight" Value="48"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                    <BrushTransition Property="Foreground" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="TabItem > TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TabItem:pointerover /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="#E2E8F0"/>
        </Style>
        <Style Selector="TabItem:pointerover /template/ ContentPresenter">
            <Setter Property="Foreground" Value="#0F172A"/>
        </Style>
        <Style Selector="TabItem:pointerover">
            <Setter Property="Foreground" Value="#0F172A"/>
        </Style>
        <Style Selector="TabItem:selected /template/ ContentPresenter">
            <Setter Property="Foreground" Value="#4338CA"/>
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Background" Value="#E0E7FF"/>
            <Setter Property="Foreground" Value="#4338CA"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <!-- Hide the default pipe in fluent theme -->
        <Style Selector="TabItem:selected /template/ Border#PART_SelectedPipe">
            <Setter Property="IsVisible" Value="False"/>
        </Style>

        <!-- Card Borders with light shadows -->
        <Style Selector="Border.Card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BoxShadow" Value="0 2 8 0 #08000000"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*" Margin="24">
        <!-- Shell Header -->
        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,24">
            <StackPanel Spacing="6" VerticalAlignment="Center">
                <TextBlock Text="{Binding AppTitleText}"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#0F172A"/>
                <TextBlock Text="{Binding AppSubtitleText}"
                           FontSize="14"
                           Foreground="#64748B"/>
            </StackPanel>

            <components:ConnectionStatusView Grid.Column="1" VerticalAlignment="Center"/>
        </Grid>

        <!-- Shell Sidebar Navigation & Main Content -->
        <TabControl Grid.Row="1" TabStripPlacement="Left">
            <TabItem Header="{Binding WorkflowsSectionText}">
                <pages:WorkflowPage />
            </TabItem>
            <TabItem Header="{Binding RunsSectionText}">
                <pages:RunMonitorPage />
            </TabItem>
            <TabItem Header="{Binding DataTabText}">
                <pages:DataPage />
            </TabItem>
            <TabItem Header="{Binding LogsTabText}">
                <pages:LogsAuditPage />
            </TabItem>
            <TabItem Header="{Binding SettingsMenuText}">
                <pages:SettingsPage />
            </TabItem>
        </TabControl>
    </Grid>
</Window>
