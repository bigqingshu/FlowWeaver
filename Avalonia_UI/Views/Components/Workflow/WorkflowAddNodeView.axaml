<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Avalonia_UI.ViewModels"
             x:Class="Avalonia_UI.Views.Components.Workflow.WorkflowAddNodeView"
             x:DataType="vm:MainWindowViewModel">
    <Border Padding="10"
            BorderBrush="{DynamicResource ControlBorderBrush}"
            BorderThickness="1"
            CornerRadius="4">
        <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                <TextBlock Text="{Binding AddNodeText}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <Button Grid.Column="1"
                        Content="{Binding CloseText}"
                        Command="{Binding CloseWorkflowAddNodePanelCommand}"
                        MinWidth="64"/>
                <Button Grid.Column="2"
                        Content="{Binding AddNodeText}"
                        Command="{Binding AddWorkflowDefinitionDraftNodeCommand}"
                        MinWidth="84"/>
            </Grid>

            <Grid Grid.Row="1"
                  ColumnDefinitions="80,*"
                  ColumnSpacing="8"
                  RowSpacing="6"
                  IsVisible="{Binding HasWorkflowDefinition}">
                <TextBlock Text="{Binding NodeTypeText}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <Grid Grid.Column="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <ComboBox ItemsSource="{Binding NodeDefinitions}"
                              SelectedItem="{Binding SelectedNewDraftNodeDefinition, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="vm:NodeDefinitionListItemViewModel"
                                          x:DataType="vm:NodeDefinitionListItemViewModel">
                                <Grid RowDefinitions="Auto,Auto">
                                    <TextBlock Text="{Binding DisplayNameText}"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Grid.Row="1"
                                               Text="{Binding TypeText}"
                                               FontSize="11"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </Grid>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Panel Grid.Column="1"
                           Background="Transparent"
                           ToolTip.Tip="{Binding RefreshNodeDefinitionsDisabledReasonText}">
                        <Button Content="{Binding RefreshText}"
                                Command="{Binding RefreshNodeDefinitionsCommand}"
                                MinWidth="72"/>
                    </Panel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>
