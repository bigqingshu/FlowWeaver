<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Avalonia_UI.ViewModels"
             x:Class="Avalonia_UI.Views.Components.Workflow.WorkflowAddNodeView"
             x:DataType="vm:MainWindowViewModel">
    <Border Classes="Card" Padding="14">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
            <TextBlock Text="{Binding AddNodeText}"
                       FontSize="16"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>

            <Grid Grid.Column="1"
                  ColumnDefinitions="Auto,*"
                  ColumnSpacing="8"
                  IsVisible="{Binding HasWorkflowDefinition}">
                <TextBlock Text="{Binding NodeTypeText}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding AddableNodeDefinitions}"
                          SelectedItem="{Binding SelectedNewDraftNodeDefinition, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate DataType="vm:NodeDefinitionListItemViewModel"
                                      x:DataType="vm:NodeDefinitionListItemViewModel">
                            <Grid RowDefinitions="Auto,Auto,Auto">
                                <TextBlock Text="{Binding DisplayNameText}"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Grid.Row="1"
                                           Text="{Binding TypeText}"
                                           FontSize="11"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Row="2"
                                           Text="{Binding SourceText}"
                                           FontSize="11"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Grid>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>

            <Button Grid.Column="2"
                    Content="{Binding AddNodeText}"
                    Command="{Binding AddWorkflowDefinitionDraftNodeCommand}"
                    MinWidth="84"/>

            <Panel Grid.Column="3"
                   Background="Transparent"
                   ToolTip.Tip="{Binding RefreshNodeDefinitionsDisabledReasonText}">
                <Button Content="{Binding RefreshText}"
                        Command="{Binding RefreshNodeDefinitionsCommand}"
                        MinWidth="72"/>
            </Panel>
        </Grid>
    </Border>
</UserControl>
