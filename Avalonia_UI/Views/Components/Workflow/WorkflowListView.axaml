<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Avalonia_UI.ViewModels"
             x:Class="Avalonia_UI.Views.Components.Workflow.WorkflowListView"
             x:DataType="vm:MainWindowViewModel">
    <Border Classes="Card" Padding="18">
        <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" RowSpacing="12">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                <TextBlock Text="{Binding WorkflowsSectionText}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <ProgressBar Grid.Column="1"
                             Width="88"
                             Height="8"
                             VerticalAlignment="Center"
                             IsIndeterminate="True"
                             IsVisible="{Binding IsWorkflowBusy}"/>
                <Button Grid.Column="2"
                        Content="{Binding RefreshText}"
                        Command="{Binding RefreshWorkflowsCommand}"
                        MinWidth="84"/>
            </Grid>

            <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <TextBox Text="{Binding NewWorkflowName}"
                         Watermark="{Binding WorkflowNameWatermarkText}"/>
                <Button Grid.Column="1"
                        Content="{Binding CreateText}"
                        Command="{Binding CreateTemplateWorkflowCommand}"
                        MinWidth="84"/>
            </Grid>

            <ListBox Grid.Row="2"
                     ItemsSource="{Binding Workflows}"
                     SelectedItem="{Binding SelectedWorkflow}"
                     BorderBrush="{DynamicResource ControlBorderBrush}"
                     BorderThickness="1">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="vm:WorkflowListItemViewModel"
                                  x:DataType="vm:WorkflowListItemViewModel">
                        <Grid ColumnDefinitions="*,Auto"
                              RowDefinitions="Auto,Auto"
                              ColumnSpacing="12"
                              Margin="8">
                            <TextBlock Text="{Binding Name}"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding VersionText}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding WorkflowId}"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Row="1"
                                       Grid.Column="1"
                                       Text="{Binding Status}"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Grid Grid.Row="3"
                  RowDefinitions="Auto,Auto"
                  RowSpacing="8">
                <Button Content="{Binding BackgroundRunManagement.StartText}"
                        Command="{Binding BackgroundRunManagement.StartCommand}"
                        HorizontalAlignment="Stretch"/>
                <Grid Grid.Row="1"
                      ColumnDefinitions="*,*,*"
                      ColumnSpacing="8">
                    <Panel Grid.Column="0"
                           Background="Transparent"
                           ToolTip.Tip="{Binding ImportWorkflowDisabledReasonText}">
                        <Button Content="{Binding ImportWorkflowText}"
                                Command="{Binding ImportWorkflowCommand}"
                                IsEnabled="{Binding CanUseImportWorkflowAction}"
                                HorizontalAlignment="Stretch"/>
                    </Panel>
                    <Panel Grid.Column="1"
                           Background="Transparent"
                           ToolTip.Tip="{Binding ExportSelectedWorkflowDisabledReasonText}">
                        <Button Content="{Binding ExportWorkflowText}"
                                Command="{Binding ExportSelectedWorkflowCommand}"
                                IsEnabled="{Binding CanUseExportSelectedWorkflowAction}"
                                HorizontalAlignment="Stretch"/>
                    </Panel>
                    <Panel Grid.Column="2"
                           Background="Transparent"
                           ToolTip.Tip="{Binding DeleteSelectedWorkflowDisabledReasonText}">
                        <Button x:Name="DeleteWorkflowButton"
                                Content="{Binding DeleteWorkflowText}"
                                IsEnabled="{Binding CanUseDeleteSelectedWorkflowAction}"
                                HorizontalAlignment="Stretch">
                            <Button.Flyout>
                                <Flyout>
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="{Binding DeleteWorkflowConfirmTitleText}"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding DeleteWorkflowConfirmMessageText}"
                                                   MaxWidth="260"
                                                   TextWrapping="Wrap"/>
                                        <Button Content="{Binding DeleteWorkflowText}"
                                                Click="ConfirmDeleteWorkflow"
                                                HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </Panel>
                </Grid>
            </Grid>

            <Grid Grid.Row="4" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding WorkflowMessage}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding WorkflowErrorMessage}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextErrorBrush}"
                               IsVisible="{Binding HasWorkflowError}"/>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="{Binding LastStartedRunId}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{DynamicResource TextSuccessBrush}"
                           IsVisible="{Binding HasLastStartedRun}"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
