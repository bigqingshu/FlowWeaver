<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Avalonia_UI.ViewModels"
             x:Class="Avalonia_UI.Views.Components.Workflow.WorkflowDataPreviewView"
             x:DataType="vm:MainWindowViewModel">
    <Border Classes="Card" Padding="12" MinHeight="172">
        <Grid RowDefinitions="Auto,Auto,*"
              RowSpacing="8">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto"
                  ColumnSpacing="8">
                <TextBlock Text="{Binding DataPreviewSectionText}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding DataPreviewMessage}"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           ToolTip.Tip="{Binding DataPreviewSourceText}"/>
                <Button Grid.Column="2"
                        Content="?"
                        MinWidth="28"
                        Padding="8,2"
                        ToolTip.Tip="{Binding DataPreviewPendingText}">
                    <Button.Flyout>
                        <Flyout>
                            <StackPanel MaxWidth="300" Spacing="6">
                                <TextBlock Text="{Binding DataPreviewPendingText}"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding WorkflowRunGuardText}"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>
                <ProgressBar Grid.Column="3"
                             Width="72"
                             Height="8"
                             VerticalAlignment="Center"
                             IsIndeterminate="True"
                             IsVisible="{Binding IsDataPreviewBusy}"/>
                <Button Grid.Column="4"
                        Content="{Binding PreviewSelectedNodeText}"
                        Command="{Binding PreviewSelectedWorkflowNodeCommand}"
                        MinWidth="96"/>
                <Button Grid.Column="5"
                        Content="{Binding DataPreviewDetailsText}"
                        Command="{Binding ShowDataPreviewDetailsCommand}"
                        MinWidth="84"/>
                <Button Grid.Column="6"
                        Content="{Binding RunText}"
                        Command="{Binding StartSelectedWorkflowCommand}"
                        MinWidth="72"
                        ToolTip.Tip="{Binding WorkflowRunGuardText}"/>
            </Grid>

            <TextBlock Grid.Row="1"
                       Text="{Binding DataPreviewErrorMessage}"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextErrorBrush}"
                       IsVisible="{Binding HasDataPreviewError}"/>

            <Border Grid.Row="2"
                    BorderBrush="{DynamicResource ControlBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    MinHeight="96"
                    MaxHeight="220"
                    ClipToBounds="True">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding DataPreviewColumns}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:TableDataPreviewColumnViewModel"
                                              x:DataType="vm:TableDataPreviewColumnViewModel">
                                    <Border Width="112"
                                            Padding="6"
                                            BorderBrush="{DynamicResource ControlBorderBrush}"
                                            BorderThickness="0,0,1,1">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{Binding DataPreviewRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:TableDataPreviewRowViewModel"
                                              x:DataType="vm:TableDataPreviewRowViewModel">
                                    <ItemsControl ItemsSource="{Binding Cells}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="vm:TableDataPreviewCellViewModel"
                                                          x:DataType="vm:TableDataPreviewCellViewModel">
                                                <Border Width="112"
                                                        Padding="6"
                                                        BorderBrush="{DynamicResource ControlBorderBrush}"
                                                        BorderThickness="0,0,1,1">
                                                    <TextBlock Text="{Binding Text}"
                                                               FontSize="12"
                                                               TextTrimming="CharacterEllipsis"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Border>
</UserControl>
