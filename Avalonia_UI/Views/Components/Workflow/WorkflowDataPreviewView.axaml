<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Avalonia_UI.ViewModels"
             x:Class="Avalonia_UI.Views.Components.Workflow.WorkflowDataPreviewView"
             x:DataType="vm:MainWindowViewModel">
    <Border Classes="Card" Padding="14" MinHeight="172">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto"
              RowSpacing="8">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                  ColumnSpacing="8">
                <TextBlock Text="{Binding DataPreviewSectionText}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <ProgressBar Grid.Column="1"
                             Width="72"
                             Height="8"
                             VerticalAlignment="Center"
                             IsIndeterminate="True"
                             IsVisible="{Binding IsDataPreviewBusy}"/>
                <Button Grid.Column="2"
                        Content="{Binding PreviewSelectedNodeText}"
                        Command="{Binding PreviewSelectedWorkflowNodeCommand}"
                        MinWidth="96"/>
                <Button Grid.Column="3"
                        Content="{Binding RunText}"
                        Command="{Binding StartSelectedWorkflowCommand}"
                        MinWidth="72"/>
            </Grid>

            <TextBlock Grid.Row="1"
                       Text="{Binding DataPreviewPendingText}"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>

            <StackPanel Grid.Row="2"
                        Spacing="4">
                <TextBlock Text="{Binding DataPreviewEmptyText}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           IsVisible="{Binding HasNoSelectedWorkflowDefinitionNode}"/>
                <TextBlock Text="{Binding DataPreviewMessage}"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding DataPreviewErrorMessage}"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextErrorBrush}"
                           IsVisible="{Binding HasDataPreviewError}"/>
            </StackPanel>

            <Border Grid.Row="3"
                    BorderBrush="{DynamicResource ControlBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    MaxHeight="180"
                    IsVisible="{Binding HasDataPreviewColumns}">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding DataPreviewColumns}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:TableDataPreviewColumnViewModel"
                                              x:DataType="vm:TableDataPreviewColumnViewModel">
                                    <Border Width="112"
                                            Padding="6"
                                            BorderBrush="{DynamicResource ControlBorderBrush}"
                                            BorderThickness="0,0,1,1">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{Binding DataPreviewRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:TableDataPreviewRowViewModel"
                                              x:DataType="vm:TableDataPreviewRowViewModel">
                                    <ItemsControl ItemsSource="{Binding Cells}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="vm:TableDataPreviewCellViewModel"
                                                          x:DataType="vm:TableDataPreviewCellViewModel">
                                                <Border Width="112"
                                                        Padding="6"
                                                        BorderBrush="{DynamicResource ControlBorderBrush}"
                                                        BorderThickness="0,0,1,1">
                                                    <TextBlock Text="{Binding Text}"
                                                               FontSize="12"
                                                               TextTrimming="CharacterEllipsis"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Border>
</UserControl>
