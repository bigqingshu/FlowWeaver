<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:primitives="using:Avalonia.Controls.Primitives"
             xmlns:vm="using:Avalonia_UI.ViewModels"
             x:Class="Avalonia_UI.Views.Components.Workflow.WorkflowEditorView"
             x:DataType="vm:MainWindowViewModel">
    <Border Classes="Card" Padding="14">
        <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                <TextBlock Text="{Binding DraftJsonSectionText}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <ProgressBar Grid.Column="1"
                             Width="88"
                             Height="8"
                             VerticalAlignment="Center"
                             IsIndeterminate="True"
                             IsVisible="{Binding IsWorkflowDefinitionDraftBusy}"/>
                <primitives:ToggleButton Grid.Column="2"
                                         Content="{Binding ShowAdvancedDraftJsonText}"
                                         IsChecked="{Binding IsWorkflowDraftJsonAdvancedVisible, Mode=TwoWay}"
                                         MinWidth="128"/>
            </Grid>

            <StackPanel Grid.Row="1"
                        Spacing="10"
                        IsVisible="{Binding IsWorkflowDraftJsonAdvancedVisible}">
                <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="10">
                    <Button Grid.Column="1"
                            Content="{Binding RestoreText}"
                            Command="{Binding RestoreWorkflowDefinitionDraftCommand}"
                            MinWidth="78"/>
                    <Button Grid.Column="2"
                            Content="{Binding ValidateText}"
                            Command="{Binding ValidateWorkflowDefinitionDraftCommand}"
                            MinWidth="92"/>
                    <Button Grid.Column="3"
                            Content="{Binding SaveText}"
                            Command="{Binding SaveWorkflowDefinitionDraftCommand}"
                            MinWidth="78"/>
                </Grid>

                <TextBox Text="{Binding WorkflowDefinitionDraftJson}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         FontFamily="Consolas"
                         FontSize="12"/>

                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding WorkflowDefinitionValidationMessage}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding WorkflowDefinitionValidationErrorMessage}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextErrorBrush}"
                               IsVisible="{Binding HasWorkflowDefinitionValidationError}"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
