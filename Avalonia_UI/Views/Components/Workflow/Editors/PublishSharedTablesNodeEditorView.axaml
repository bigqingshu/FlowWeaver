<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Avalonia_UI.ViewModels"
             x:Class="Avalonia_UI.Views.Components.Workflow.Editors.PublishSharedTablesNodeEditorView"
             x:DataType="vm:PublishSharedTablesNodeEditorViewModel">
    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
        <Grid ColumnDefinitions="140,*" ColumnSpacing="10">
            <TextBlock Text="{Binding ShareNameText}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBox Grid.Column="1"
                     Text="{Binding ShareNameField.InputValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>

        <Grid Grid.Row="1" RowDefinitions="Auto,Auto" RowSpacing="6">
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <TextBlock Text="{Binding InputsText}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding ExportNameText}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
            </Grid>
            <Border Grid.Row="1"
                    MaxHeight="220"
                    BorderBrush="{DynamicResource ControlBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding InputMappings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:PublishSharedTableInputMappingViewModel"
                                          x:DataType="vm:PublishSharedTableInputMappingViewModel">
                                <Grid ColumnDefinitions="*,*"
                                      ColumnSpacing="10"
                                      Margin="8,4">
                                    <TextBlock Text="{Binding InputText}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip.Tip="{Binding InputText}"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding ExportName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip.Tip="{Binding ExportName}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>

        <Grid Grid.Row="2"
              ColumnDefinitions="140,*"
              ColumnSpacing="10"
              IsVisible="{Binding HasRetentionSecondsField}">
            <TextBlock Text="{Binding RetentionSecondsText}"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBox Grid.Column="1"
                     Text="{Binding RetentionSecondsField.InputValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>
    </Grid>
</UserControl>
