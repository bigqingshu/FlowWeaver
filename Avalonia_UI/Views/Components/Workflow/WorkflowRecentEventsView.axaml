<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Avalonia_UI.ViewModels"
             xmlns:primitives="using:Avalonia.Controls.Primitives"
             x:Class="Avalonia_UI.Views.Components.Workflow.WorkflowRecentEventsView"
             x:DataType="vm:MainWindowViewModel">
    <Border Classes="Card" Padding="12">
        <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                <TextBlock Text="{Binding RecentEventsSectionText}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <primitives:ToggleButton Grid.Column="1"
                                         Content="{Binding RecentEventsToggleText}"
                                         IsChecked="{Binding IsRecentEventsExpanded, Mode=TwoWay}"
                                         IsVisible="{Binding HasMoreRecentEvents}"
                                         MinWidth="72"/>
                <Button Grid.Column="2"
                        Content="{Binding RecentEventsViewAllText}"
                        Command="{Binding ViewAllRecentEventsCommand}"
                        MinWidth="76"/>
            </Grid>

            <Grid Grid.Row="1">
                <TextBlock Text="{Binding RecentEventsEmptyText}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           IsVisible="{Binding HasNoRecentEvents}"/>
                <ItemsControl ItemsSource="{Binding VisibleRecentEvents}"
                              IsVisible="{Binding HasRecentEvents}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:RecentEventListItemViewModel"
                                      x:DataType="vm:RecentEventListItemViewModel">
                            <Grid RowDefinitions="Auto,Auto"
                                  ColumnDefinitions="Auto,*,Auto"
                                  RowSpacing="2"
                                  ColumnSpacing="8"
                                  Margin="0,0,0,6">
                                <TextBlock Text="{Binding KindText}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding Title}"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding TimestampText}"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>

                                <StackPanel Grid.Row="1"
                                            Grid.Column="1"
                                            Grid.ColumnSpan="2"
                                            Orientation="Horizontal"
                                            Spacing="6">
                                    <TextBlock Text="{Binding SourceText}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding Message}"
                                               FontSize="11"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               IsVisible="{Binding HasMessage}"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Grid>
    </Border>
</UserControl>
