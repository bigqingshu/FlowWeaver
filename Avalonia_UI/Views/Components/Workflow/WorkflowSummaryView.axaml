<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="using:Avalonia_UI.Models"
             xmlns:vm="using:Avalonia_UI.ViewModels"
             xmlns:workflow="using:Avalonia_UI.Views.Components.Workflow"
             xmlns:primitives="using:Avalonia.Controls.Primitives"
             x:Class="Avalonia_UI.Views.Components.Workflow.WorkflowSummaryView"
             x:DataType="vm:MainWindowViewModel">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="10">
        <!-- Details Card -->
        <Border Classes="Card" Padding="14">
            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                    <TextBlock Text="{Binding WorkflowDefinitionSectionText}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <ProgressBar Grid.Column="1"
                                 Width="88"
                                 Height="8"
                                 VerticalAlignment="Center"
                                 IsIndeterminate="True"
                                 IsVisible="{Binding IsLoadingWorkflowDefinition}"/>
                    <Button Grid.Column="2"
                            Content="{Binding DetailsText}"
                            Command="{Binding LoadSelectedWorkflowDefinitionCommand}"
                            MinWidth="84"/>
                </Grid>

                <Grid Grid.Row="1"
                      ColumnDefinitions="Auto,*,Auto,*"
                      RowDefinitions="Auto,Auto,Auto"
                      RowSpacing="6"
                      ColumnSpacing="10"
                      IsVisible="{Binding HasWorkflowDefinition}">
                    <TextBlock Text="{Binding NameLabelText}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Column="1" Text="{Binding WorkflowDefinitionDetail.Name}" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Grid.Column="2" Text="{Binding VersionLabelText}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Column="3" Text="{Binding WorkflowDefinitionDetail.VersionText}" Foreground="{DynamicResource TextPrimaryBrush}"/>

                    <TextBlock Grid.Row="1" Text="{Binding RevisionLabelText}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding WorkflowDefinitionDetail.RevisionId}" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding StatusLabelText}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding WorkflowDefinitionDetail.Status}" Foreground="{DynamicResource TextPrimaryBrush}"/>

                    <TextBlock Grid.Row="2" Text="{Binding HashLabelText}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding WorkflowDefinitionDetail.DefinitionHash}" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding UpdatedLabelText}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding WorkflowDefinitionDetail.UpdatedAtText}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                </Grid>

                <StackPanel Grid.Row="2" Spacing="4">
                    <TextBlock Text="{Binding WorkflowDefinitionMessage}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding WorkflowDefinitionErrorMessage}" TextWrapping="Wrap" Foreground="{DynamicResource TextErrorBrush}" IsVisible="{Binding HasWorkflowDefinitionError}"/>
                </StackPanel>
            </Grid>
        </Border>

        <workflow:WorkflowAddNodeView />

        <workflow:WorkflowSelectedNodeConfigView />

        <workflow:WorkflowEditorView IsVisible="{Binding IsWorkflowDraftJsonAdvancedVisible}"/>

        <!-- Connections Card -->
        <Border Classes="Card" Padding="14">
            <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                    <TextBlock Text="{Binding ConnectionsSectionText}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding WorkflowDefinitionDetail.ConnectionCountText}"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <primitives:ToggleButton Grid.Column="2"
                                             Content="{Binding ShowConnectionsText}"
                                             IsChecked="{Binding IsWorkflowConnectionsAdvancedVisible, Mode=TwoWay}"
                                             MinWidth="112"/>
                </Grid>

                <StackPanel Grid.Row="1"
                            Spacing="8"
                            IsVisible="{Binding IsWorkflowConnectionsAdvancedVisible}">
                    <ListBox ItemsSource="{Binding WorkflowDefinitionDetail.Connections}"
                             BorderBrush="{DynamicResource ControlBorderBrush}"
                             BorderThickness="1"
                             MaxHeight="140">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:WorkflowDefinitionConnectionListItemViewModel"
                                          x:DataType="vm:WorkflowDefinitionConnectionListItemViewModel">
                                <Grid RowDefinitions="Auto,Auto" Margin="8" RowSpacing="4">
                                    <TextBlock Text="{Binding EdgeText}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Grid.Row="1" Text="{Binding ConnectionId}" FontSize="12" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Spacing="8"
                                IsVisible="{Binding HasWorkflowDefinition}">
                    <TextBlock Text="{Binding AddConnectionText}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>

                    <Grid ColumnDefinitions="120,*"
                          RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                          ColumnSpacing="10"
                          RowSpacing="6">
                        <TextBlock Text="{Binding ConnectionIdText}"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding NewDraftConnectionId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Grid.Row="1"
                                   Text="{Binding SourceNodeText}"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <StackPanel Grid.Row="1"
                                    Grid.Column="1"
                                    Spacing="4">
                            <ComboBox ItemsSource="{Binding WorkflowDefinitionDraftStructure.Nodes}"
                                      SelectedItem="{Binding SelectedNewDraftConnectionSourceNode, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate DataType="models:WorkflowDefinitionDraftNode"
                                                  x:DataType="models:WorkflowDefinitionDraftNode">
                                        <Grid RowDefinitions="Auto,Auto">
                                            <TextBlock Text="{Binding NodeInstanceId}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding NodeTypeDisplayName}"
                                                       FontSize="11"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBox Text="{Binding NewDraftConnectionSourceNodeId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <TextBlock Grid.Row="2"
                                   Text="{Binding SourcePortText}"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBox Grid.Row="2"
                                  Grid.Column="1"
                                  Text="{Binding NewDraftConnectionSourcePort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Grid.Row="3"
                                   Text="{Binding TargetNodeText}"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <StackPanel Grid.Row="3"
                                    Grid.Column="1"
                                    Spacing="4">
                            <ComboBox ItemsSource="{Binding WorkflowDefinitionDraftStructure.Nodes}"
                                      SelectedItem="{Binding SelectedNewDraftConnectionTargetNode, Mode=TwoWay}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate DataType="models:WorkflowDefinitionDraftNode"
                                                  x:DataType="models:WorkflowDefinitionDraftNode">
                                        <Grid RowDefinitions="Auto,Auto">
                                            <TextBlock Text="{Binding NodeInstanceId}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding NodeTypeDisplayName}"
                                                       FontSize="11"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBox Text="{Binding NewDraftConnectionTargetNodeId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <TextBlock Grid.Row="4"
                                   Text="{Binding TargetPortText}"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBox Grid.Row="4"
                                  Grid.Column="1"
                                  Text="{Binding NewDraftConnectionTargetPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Row="5"
                                Grid.Column="1"
                                Content="{Binding AddConnectionText}"
                                Command="{Binding AddWorkflowDefinitionDraftConnectionCommand}"
                                HorizontalAlignment="Right"
                                MinWidth="128"/>
                    </Grid>

                    <TextBlock Text="{Binding DeleteConnectionText}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>

                    <Grid ColumnDefinitions="120,*,Auto"
                          ColumnSpacing="10">
                        <TextBlock Text="{Binding ConnectionIdText}"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding SelectedWorkflowDefinitionDraftConnectionId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="2"
                                Content="{Binding DeleteConnectionText}"
                                Command="{Binding DeleteWorkflowDefinitionDraftConnectionCommand}"
                                MinWidth="128"/>
                    </Grid>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
