<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Avalonia_UI.ViewModels"
             x:Class="Avalonia_UI.Views.Components.Workflow.WorkflowSummaryView"
             x:DataType="vm:MainWindowViewModel">
    <Grid RowDefinitions="Auto,*,*" RowSpacing="10">
        <!-- Details & Revisions Card -->
        <Border Classes="Card" Padding="14">
            <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="10">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                    <TextBlock Text="{Binding WorkflowDefinitionSectionText}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <ProgressBar Grid.Column="1"
                                 Width="88"
                                 Height="8"
                                 VerticalAlignment="Center"
                                 IsIndeterminate="True"
                                 IsVisible="{Binding IsLoadingWorkflowDefinition}"/>
                    <Button Grid.Column="2"
                            Content="{Binding DetailsText}"
                            Command="{Binding LoadSelectedWorkflowDefinitionCommand}"
                            MinWidth="84"/>
                </Grid>

                <Grid Grid.Row="1"
                      ColumnDefinitions="Auto,*,Auto,*"
                      RowDefinitions="Auto,Auto,Auto"
                      RowSpacing="6"
                      ColumnSpacing="10"
                      IsVisible="{Binding HasWorkflowDefinition}">
                    <TextBlock Text="{Binding NameLabelText}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Column="1" Text="{Binding WorkflowDefinitionDetail.Name}" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Grid.Column="2" Text="{Binding VersionLabelText}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Column="3" Text="{Binding WorkflowDefinitionDetail.VersionText}" Foreground="{DynamicResource TextPrimaryBrush}"/>

                    <TextBlock Grid.Row="1" Text="{Binding RevisionLabelText}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding WorkflowDefinitionDetail.RevisionId}" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding StatusLabelText}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding WorkflowDefinitionDetail.Status}" Foreground="{DynamicResource TextPrimaryBrush}"/>

                    <TextBlock Grid.Row="2" Text="{Binding HashLabelText}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding WorkflowDefinitionDetail.DefinitionHash}" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding UpdatedLabelText}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding WorkflowDefinitionDetail.UpdatedAtText}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                </Grid>

                <ListBox Grid.Row="2"
                         ItemsSource="{Binding WorkflowDefinitionDetail.Revisions}"
                         BorderBrush="{DynamicResource ControlBorderBrush}"
                         BorderThickness="1"
                         MinHeight="100">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="vm:WorkflowRevisionListItemViewModel"
                                      x:DataType="vm:WorkflowRevisionListItemViewModel">
                            <Grid ColumnDefinitions="*,Auto"
                                  RowDefinitions="Auto,Auto,Auto"
                                  ColumnSpacing="12"
                                  Margin="8">
                                <TextBlock Text="{Binding RevisionId}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding VersionText}" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Row="1" Text="{Binding DefinitionHash}" FontSize="12" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CreatedAtText}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Row="2" Text="{Binding CreatedByText}" FontSize="12" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="3" Spacing="4">
                    <TextBlock Text="{Binding WorkflowDefinitionMessage}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding WorkflowDefinitionErrorMessage}" TextWrapping="Wrap" Foreground="{DynamicResource TextErrorBrush}" IsVisible="{Binding HasWorkflowDefinitionError}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Nodes Card -->
        <Border Grid.Row="1" Classes="Card" Padding="14">
            <Grid RowDefinitions="Auto,*" RowSpacing="10">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <TextBlock Text="{Binding NodesSectionText}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding WorkflowDefinitionDetail.NodeCountText}"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </Grid>

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding WorkflowDefinitionDetail.Nodes}"
                         BorderBrush="{DynamicResource ControlBorderBrush}"
                         BorderThickness="1"
                         MinHeight="100">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="vm:WorkflowDefinitionNodeListItemViewModel"
                                      x:DataType="vm:WorkflowDefinitionNodeListItemViewModel">
                            <Grid ColumnDefinitions="*,Auto"
                                  RowDefinitions="Auto,Auto,Auto"
                                  ColumnSpacing="12"
                                  Margin="8">
                                <TextBlock Text="{Binding NodeInstanceId}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding EnabledText}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Row="1" Text="{Binding TypeText}" FontSize="12" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DisplayNameText}" FontSize="12" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="{Binding ConfigJson}" FontSize="12" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Connections Card -->
        <Border Grid.Row="2" Classes="Card" Padding="14">
            <Grid RowDefinitions="Auto,*" RowSpacing="10">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <TextBlock Text="{Binding ConnectionsSectionText}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding WorkflowDefinitionDetail.ConnectionCountText}"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </Grid>

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding WorkflowDefinitionDetail.Connections}"
                         BorderBrush="{DynamicResource ControlBorderBrush}"
                         BorderThickness="1"
                         MinHeight="100">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="vm:WorkflowDefinitionConnectionListItemViewModel"
                                      x:DataType="vm:WorkflowDefinitionConnectionListItemViewModel">
                            <Grid RowDefinitions="Auto,Auto" Margin="8" RowSpacing="4">
                                <TextBlock Text="{Binding EdgeText}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Grid.Row="1" Text="{Binding ConnectionId}" FontSize="12" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
