<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:primitives="using:Avalonia.Controls.Primitives"
             xmlns:vm="using:Avalonia_UI.ViewModels"
             x:Class="Avalonia_UI.Views.Components.Workflow.WorkflowNodeListView"
             x:DataType="vm:MainWindowViewModel">
    <Border Classes="Card" Padding="14">
        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="10">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <TextBlock Text="{Binding WorkflowNodesSectionText}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding WorkflowDefinitionDraftNodeCountText}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
            </Grid>

            <ListBox Grid.Row="1"
                     ItemsSource="{Binding WorkflowDefinitionDraftNodes}"
                     SelectedItem="{Binding SelectedWorkflowDefinitionNode}"
                     BorderBrush="{DynamicResource ControlBorderBrush}"
                     BorderThickness="1">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="vm:WorkflowDefinitionNodeListItemViewModel"
                                  x:DataType="vm:WorkflowDefinitionNodeListItemViewModel">
                        <Grid ColumnDefinitions="*,Auto"
                              RowDefinitions="Auto,Auto,Auto,Auto"
                              ColumnSpacing="12"
                              Margin="8">
                            <TextBlock Text="{Binding NodeInstanceId}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding EnabledText}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Row="1" Text="{Binding TypeText}" FontSize="12" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DisplayNameText}" FontSize="12" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Row="2"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding NodeEditorStatusText}"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Row="3" Grid.ColumnSpan="2" Text="{Binding ConfigJson}" FontSize="12" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Grid.Row="2" Spacing="8">
                <TextBlock Text="{Binding NodeActionsSectionText}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>

                <WrapPanel Orientation="Horizontal"
                           HorizontalAlignment="Right">
                    <Button Content="{Binding MoveNodeUpText}"
                            Command="{Binding MoveSelectedWorkflowDefinitionDraftNodeUpCommand}"
                            MinWidth="84"
                            Margin="0,0,8,8"/>
                    <Button Content="{Binding MoveNodeDownText}"
                            Command="{Binding MoveSelectedWorkflowDefinitionDraftNodeDownCommand}"
                            MinWidth="84"
                            Margin="0,0,8,8"/>
                    <Button Content="{Binding DeleteNodeText}"
                            Command="{Binding DeleteWorkflowDefinitionDraftNodeCommand}"
                            MinWidth="104"
                            Margin="0,0,8,8"/>
                    <primitives:ToggleButton Content="{Binding ShowAdvancedDraftJsonText}"
                                             IsChecked="{Binding IsWorkflowDraftJsonAdvancedVisible, Mode=TwoWay}"
                                             MinWidth="128"
                                             Margin="0,0,0,8"/>
                </WrapPanel>

                <TextBlock Text="{Binding WorkflowDefinitionValidationMessage}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding WorkflowDefinitionValidationErrorMessage}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextErrorBrush}"
                           IsVisible="{Binding HasWorkflowDefinitionValidationError}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
