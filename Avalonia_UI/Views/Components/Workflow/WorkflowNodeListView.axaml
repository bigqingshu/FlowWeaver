<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:primitives="using:Avalonia.Controls.Primitives"
             xmlns:vm="using:Avalonia_UI.ViewModels"
             x:Class="Avalonia_UI.Views.Components.Workflow.WorkflowNodeListView"
             x:DataType="vm:MainWindowViewModel">
    <Border Classes="Card" Padding="14">
        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="10">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <TextBlock Text="{Binding WorkflowNodesSectionText}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding WorkflowDefinitionDraftNodeCountText}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
            </Grid>

            <ListBox Grid.Row="1"
                     ItemsSource="{Binding WorkflowDefinitionDraftNodes}"
                     SelectedItem="{Binding SelectedWorkflowDefinitionNode}"
                     BorderBrush="{DynamicResource ControlBorderBrush}"
                     BorderThickness="1">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="vm:WorkflowDefinitionNodeListItemViewModel"
                                  x:DataType="vm:WorkflowDefinitionNodeListItemViewModel">
                        <Grid ColumnDefinitions="Auto,Auto,*,Auto"
                              RowDefinitions="Auto,Auto"
                              ColumnSpacing="10"
                              RowSpacing="2"
                              Margin="8">
                            <CheckBox Grid.RowSpan="2"
                                      IsChecked="{Binding IsBatchSelected, Mode=TwoWay}"
                                      VerticalAlignment="Top"
                                      Margin="0,1,0,0"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding OrderText}"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding TitleText}"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Grid.Column="3"
                                       Text="{Binding EnabledText}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Row="1"
                                       Grid.Column="2"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding NodeSummaryText}"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Grid.Row="2" Spacing="8">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                    <TextBlock Text="{Binding NodeActionsSectionText}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <Button Grid.Column="1"
                            Content="?"
                            MinWidth="28"
                            Padding="8,2"
                            ToolTip.Tip="{Binding NodeMoveSemanticsText}">
                        <Button.Flyout>
                            <Flyout>
                                <TextBlock Text="{Binding NodeMoveSemanticsText}"
                                           MaxWidth="260"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                </Grid>
                <WrapPanel Orientation="Horizontal"
                           HorizontalAlignment="Right">
                    <Panel Background="Transparent"
                           ToolTip.Tip="{Binding MoveSelectedWorkflowDefinitionDraftNodeUpDisabledReasonText}"
                           Margin="0,0,8,8">
                        <Button Content="{Binding MoveNodeUpText}"
                                Command="{Binding MoveSelectedWorkflowDefinitionDraftNodeUpCommand}"
                                MinWidth="84"/>
                    </Panel>
                    <Panel Background="Transparent"
                           ToolTip.Tip="{Binding MoveSelectedWorkflowDefinitionDraftNodeDownDisabledReasonText}"
                           Margin="0,0,8,8">
                        <Button Content="{Binding MoveNodeDownText}"
                                Command="{Binding MoveSelectedWorkflowDefinitionDraftNodeDownCommand}"
                                MinWidth="84"/>
                    </Panel>
                    <Panel Background="Transparent"
                           ToolTip.Tip="{Binding CopyWorkflowDefinitionDraftNodeDisabledReasonText}"
                           Margin="0,0,8,8">
                        <Button Content="{Binding CopyNodeText}"
                                Command="{Binding CopyWorkflowDefinitionDraftNodeCommand}"
                                MinWidth="104"/>
                    </Panel>
                    <Panel Background="Transparent"
                           ToolTip.Tip="{Binding DeleteWorkflowDefinitionDraftNodeDisabledReasonText}"
                           Margin="0,0,8,8">
                        <Button Content="{Binding DeleteNodeText}"
                                Command="{Binding DeleteWorkflowDefinitionDraftNodeCommand}"
                                MinWidth="104"/>
                    </Panel>
                    <Panel Background="Transparent"
                           ToolTip.Tip="{Binding DeleteSelectedWorkflowDefinitionDraftNodesDisabledReasonText}"
                           Margin="0,0,8,8">
                        <Button Content="{Binding DeleteSelectedNodesText}"
                                Command="{Binding DeleteSelectedWorkflowDefinitionDraftNodesCommand}"
                                MinWidth="104"/>
                    </Panel>
                    <primitives:ToggleButton Content="{Binding ShowAdvancedDraftJsonText}"
                                             IsChecked="{Binding IsWorkflowDraftJsonAdvancedVisible, Mode=TwoWay}"
                                             MinWidth="128"
                                             Margin="0,0,0,8"/>
                </WrapPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
