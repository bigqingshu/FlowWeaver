<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:primitives="using:Avalonia.Controls.Primitives"
             xmlns:vm="using:Avalonia_UI.ViewModels"
             x:Class="Avalonia_UI.Views.Components.Workflow.WorkflowNodeListView"
             x:DataType="vm:MainWindowViewModel">
    <Border Classes="Card" Padding="14">
        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="10">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <TextBlock Text="{Binding WorkflowNodesSectionText}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding WorkflowDefinitionDraftNodeCountText}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
            </Grid>

            <ListBox Grid.Row="1"
                     ItemsSource="{Binding WorkflowDefinitionDraftNodes}"
                     SelectedItem="{Binding SelectedWorkflowDefinitionNode}"
                     BorderBrush="{DynamicResource ControlBorderBrush}"
                     BorderThickness="1">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="vm:WorkflowDefinitionNodeListItemViewModel"
                                  x:DataType="vm:WorkflowDefinitionNodeListItemViewModel">
                        <Grid ColumnDefinitions="*,Auto"
                              RowDefinitions="Auto,Auto,Auto,Auto"
                              ColumnSpacing="12"
                              Margin="8">
                            <TextBlock Text="{Binding NodeInstanceId}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding EnabledText}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Row="1" Text="{Binding TypeText}" FontSize="12" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DisplayNameText}" FontSize="12" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Row="2"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding NodeEditorStatusText}"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Row="3" Grid.ColumnSpan="2" Text="{Binding ConfigJson}" FontSize="12" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Grid.Row="2" Spacing="8">
                <TextBlock Text="{Binding NodeActionsSectionText}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>

                <WrapPanel Orientation="Horizontal"
                           HorizontalAlignment="Right">
                    <Button Content="{Binding MoveNodeUpText}"
                            Command="{Binding MoveSelectedWorkflowDefinitionDraftNodeUpCommand}"
                            MinWidth="84"
                            Margin="0,0,8,8"/>
                    <Button Content="{Binding MoveNodeDownText}"
                            Command="{Binding MoveSelectedWorkflowDefinitionDraftNodeDownCommand}"
                            MinWidth="84"
                            Margin="0,0,8,8"/>
                    <Button Content="{Binding DeleteNodeText}"
                            Command="{Binding DeleteWorkflowDefinitionDraftNodeCommand}"
                            MinWidth="104"
                            Margin="0,0,8,8"/>
                    <primitives:ToggleButton Content="{Binding ShowAdvancedDraftJsonText}"
                                             IsChecked="{Binding IsWorkflowDraftJsonAdvancedVisible, Mode=TwoWay}"
                                             MinWidth="128"
                                             Margin="0,0,0,8"/>
                </WrapPanel>

                <TextBlock Text="{Binding WorkflowDefinitionValidationMessage}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding WorkflowDefinitionValidationErrorMessage}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextErrorBrush}"
                           IsVisible="{Binding HasWorkflowDefinitionValidationError}"/>

                <Border BorderBrush="{DynamicResource ControlBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10"
                        MinHeight="128">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
                          RowSpacing="8">
                        <Grid ColumnDefinitions="*,Auto,Auto"
                              ColumnSpacing="8">
                            <TextBlock Text="{Binding DataPreviewSectionText}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <ProgressBar Grid.Column="1"
                                         Width="72"
                                         Height="8"
                                         VerticalAlignment="Center"
                                         IsIndeterminate="True"
                                         IsVisible="{Binding IsDataPreviewBusy}"/>
                            <Button Grid.Column="2"
                                    Content="{Binding DataPreviewRefreshText}"
                                    Command="{Binding RefreshSelectedWorkflowNodeDataPreviewCommand}"
                                    MinWidth="96"/>
                        </Grid>
                        <TextBlock Grid.Row="1"
                                   Text="{Binding DataPreviewPendingText}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Grid.Row="2"
                                   Text="{Binding DataPreviewEmptyText}"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   IsVisible="{Binding HasNoSelectedWorkflowDefinitionNode}"/>
                        <Grid Grid.Row="2"
                              ColumnDefinitions="88,*"
                              RowDefinitions="Auto,Auto,Auto"
                              ColumnSpacing="8"
                              RowSpacing="4"
                              IsVisible="{Binding HasSelectedWorkflowDefinitionNode}">
                            <TextBlock Text="{Binding NodeInstanceIdText}"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding SelectedWorkflowDefinitionNode.NodeInstanceId}"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding NodeTypeText}"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Row="1"
                                       Grid.Column="1"
                                       Text="{Binding SelectedWorkflowDefinitionNode.TypeText}"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Grid.Row="2"
                                       Text="{Binding DisplayNameText}"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Row="2"
                                       Grid.Column="1"
                                       Text="{Binding SelectedWorkflowDefinitionNode.DisplayNameText}"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </Grid>
                        <Border Grid.Row="3"
                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="8"
                                MaxHeight="108"
                                IsVisible="{Binding HasSelectedWorkflowDefinitionNode}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <TextBlock Text="{Binding SelectedWorkflowDefinitionNode.ConfigJson}"
                                           FontFamily="Consolas"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </ScrollViewer>
                        </Border>
                        <StackPanel Grid.Row="4"
                                    Spacing="4">
                            <TextBlock Text="{Binding DataPreviewMessage}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Text="{Binding DataPreviewErrorMessage}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextErrorBrush}"
                                       IsVisible="{Binding HasDataPreviewError}"/>
                        </StackPanel>
                        <Border Grid.Row="5"
                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                MaxHeight="150"
                                IsVisible="{Binding HasDataPreviewRows}">
                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <ItemsControl ItemsSource="{Binding DataPreviewColumns}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="vm:TableDataPreviewColumnViewModel"
                                                          x:DataType="vm:TableDataPreviewColumnViewModel">
                                                <Border Width="112"
                                                        Padding="6"
                                                        BorderBrush="{DynamicResource ControlBorderBrush}"
                                                        BorderThickness="0,0,1,1">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <ItemsControl ItemsSource="{Binding DataPreviewRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="vm:TableDataPreviewRowViewModel"
                                                          x:DataType="vm:TableDataPreviewRowViewModel">
                                                <ItemsControl ItemsSource="{Binding Cells}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="vm:TableDataPreviewCellViewModel"
                                                                      x:DataType="vm:TableDataPreviewCellViewModel">
                                                            <Border Width="112"
                                                                    Padding="6"
                                                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                                                    BorderThickness="0,0,1,1">
                                                                <TextBlock Text="{Binding Text}"
                                                                           FontSize="12"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
