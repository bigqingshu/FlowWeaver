<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Avalonia_UI.ViewModels"
             x:Class="Avalonia_UI.Views.Components.Workflow.WorkflowNodeCatalogView"
             x:DataType="vm:MainWindowViewModel">
    <Border Classes="Card" Padding="14">
        <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="10">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                <TextBlock Text="{Binding NodeCatalogSectionText}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <ProgressBar Grid.Column="1"
                             Width="88"
                             Height="8"
                             VerticalAlignment="Center"
                             IsIndeterminate="True"
                             IsVisible="{Binding IsLoadingNodeDefinitions}"/>
                <Panel Grid.Column="2"
                       Background="Transparent"
                       ToolTip.Tip="{Binding RefreshNodeDefinitionsDisabledReasonText}">
                    <Button Content="{Binding RefreshText}"
                            Command="{Binding RefreshNodeDefinitionsCommand}"
                            MinWidth="84"/>
                </Panel>
            </Grid>

            <Grid Grid.Row="1"
                  ColumnDefinitions="1.4*,1*,1*,Auto,Auto"
                  ColumnSpacing="12"
                  IsVisible="{Binding HasNodeDefinitions}">
                <TextBlock Text="{Binding NodeText}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Grid.Column="1" Text="{Binding InputsText}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Grid.Column="2" Text="{Binding OutputsText}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Grid.Column="3" Text="{Binding ModeText}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Grid.Column="4" Text="{Binding TimeoutText}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
            </Grid>

            <Border Grid.Row="2"
                    BorderBrush="{DynamicResource ControlBorderBrush}"
                    BorderThickness="1"
                    MinHeight="120"
                    IsVisible="{Binding HasNodeDefinitionCatalogEmptyState}">
                <TextBlock Text="{Binding NodeCatalogEmptyStateText}"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="18"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
            </Border>

            <ListBox Grid.Row="2"
                     ItemsSource="{Binding NodeDefinitions}"
                     BorderBrush="{DynamicResource ControlBorderBrush}"
                     BorderThickness="1"
                     IsVisible="{Binding HasNodeDefinitions}"
                     MinHeight="120">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="vm:NodeDefinitionListItemViewModel"
                                  x:DataType="vm:NodeDefinitionListItemViewModel">
                        <Grid ColumnDefinitions="1.4*,1*,1*,Auto,Auto"
                              RowDefinitions="Auto,Auto"
                              ColumnSpacing="12"
                              Margin="8">
                            <TextBlock Text="{Binding DisplayNameText}"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <StackPanel Grid.Row="1" Spacing="2">
                                <TextBlock Text="{Binding TypeText}"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding ConfigSchemaSummaryText}"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Grid.RowSpan="2"
                                       Text="{Binding InputPortsText}"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="2"
                                       Grid.RowSpan="2"
                                       Text="{Binding OutputPortsText}"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="3"
                                       Grid.RowSpan="2"
                                       Text="{Binding ExecutionMode}"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Column="4"
                                       Grid.RowSpan="2"
                                       Text="{Binding TimeoutText}"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Grid.Row="3" Spacing="4">
                <TextBlock Text="{Binding NodeDefinitionCatalogMessage}"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding NodeDefinitionCatalogErrorMessage}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextErrorBrush}"
                           IsVisible="{Binding HasNodeDefinitionCatalogError}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
