<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Avalonia_UI.ViewModels"
             x:Class="Avalonia_UI.Views.Components.Shell.ShellNotificationHostView"
             x:DataType="vm:MainWindowViewModel">
    <Border Width="420"
            MaxHeight="220"
            Padding="14"
            Background="{DynamicResource CardBackgroundBrush}"
            BorderBrush="{DynamicResource PrimaryButtonBackgroundBrush}"
            BorderThickness="1"
            CornerRadius="8"
            BoxShadow="0 10 28 0 #50000000"
            IsVisible="{Binding IsNotificationOpen}">
        <Grid RowDefinitions="Auto,*,Auto"
              ColumnDefinitions="*,Auto"
              RowSpacing="8"
              ColumnSpacing="12">
            <Grid ColumnDefinitions="Auto,*"
                  ColumnSpacing="8">
                <Border Padding="6,2"
                        CornerRadius="4"
                        Background="{DynamicResource ControlBackgroundPressedBrush}">
                    <TextBlock Text="{Binding NotificationKindText}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                </Border>
                <TextBlock Text="{Binding NotificationTitle}"
                           Grid.Column="1"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
            </Grid>
            <Button Grid.Column="1"
                    Content="x"
                    Width="28"
                    Height="28"
                    MinWidth="28"
                    Padding="0"
                    Command="{Binding CloseNotificationCommand}"/>
            <ScrollViewer Grid.Row="1"
                          Grid.ColumnSpan="2"
                          MaxHeight="140"
                          VerticalScrollBarVisibility="Auto">
                <TextBlock Text="{Binding NotificationMessage}"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
            </ScrollViewer>
            <ProgressBar Grid.Row="2"
                         Grid.ColumnSpan="2"
                         Height="4"
                         Minimum="0"
                         Maximum="1"
                         Value="{Binding NotificationCountdownProgress}"
                         Background="{DynamicResource ControlBackgroundPressedBrush}"
                         Foreground="{DynamicResource PrimaryButtonBackgroundBrush}"
                         IsVisible="{Binding HasNotificationCountdown}">
                <ProgressBar.Transitions>
                    <Transitions>
                        <DoubleTransition Property="Value"
                                          Duration="0:0:0.08"/>
                    </Transitions>
                </ProgressBar.Transitions>
            </ProgressBar>
        </Grid>
    </Border>
</UserControl>
