<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Avalonia_UI.ViewModels"
             x:Class="Avalonia_UI.Views.Components.Shell.ShellNotificationHostView"
             x:DataType="vm:MainWindowViewModel">
    <Border Classes="Card"
            Width="360"
            Padding="12"
            IsVisible="{Binding IsNotificationOpen}">
        <Grid RowDefinitions="Auto,Auto"
              ColumnDefinitions="*,Auto"
              RowSpacing="6"
              ColumnSpacing="10">
            <StackPanel Orientation="Horizontal"
                        Spacing="8">
                <TextBlock Text="{Binding NotificationKindText}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding NotificationTitle}"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
            </StackPanel>
            <Button Grid.Column="1"
                    Content="x"
                    MinWidth="28"
                    Padding="8,2"
                    Command="{Binding CloseNotificationCommand}"/>
            <TextBlock Grid.Row="1"
                       Grid.ColumnSpan="2"
                       Text="{Binding NotificationMessage}"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
        </Grid>
    </Border>
</UserControl>
