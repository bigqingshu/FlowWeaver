<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Avalonia_UI.ViewModels"
             x:Class="Avalonia_UI.Views.Components.Data.TableRefListView"
             x:DataType="vm:MainWindowViewModel">
    <Border Classes="Card" Padding="14">
        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="10">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                <TextBlock Text="{Binding TableRefsSectionText}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="#14171A"/>
                <ProgressBar Grid.Column="1"
                             Width="88"
                             Height="8"
                             VerticalAlignment="Center"
                             IsIndeterminate="True"
                             IsVisible="{Binding IsDataBusy}"/>
                <Button Grid.Column="2"
                        Content="{Binding RefreshText}"
                        Command="{Binding RefreshTableRefsCommand}"
                        MinWidth="84"/>
            </Grid>

            <ListBox Grid.Row="1"
                     ItemsSource="{Binding TableRefs}"
                     BorderBrush="#E1E5EA"
                     BorderThickness="1">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="vm:TableRefListItemViewModel"
                                  x:DataType="vm:TableRefListItemViewModel">
                        <Grid ColumnDefinitions="*,Auto"
                              RowDefinitions="Auto,Auto,Auto,Auto"
                              ColumnSpacing="12"
                              Margin="8">
                            <TextBlock Text="{Binding LogicalTableId}"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="#1F2933"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding LifecycleStatus}"
                                       FontWeight="SemiBold"
                                       Foreground="#4B5563"/>
                            <TextBlock Grid.Row="1"
                                       Text="{Binding TableRefId}"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="#697586"/>
                            <TextBlock Grid.Row="1"
                                       Grid.Column="1"
                                       Text="{Binding VersionText}"
                                       FontSize="12"
                                       Foreground="#4B5563"/>
                            <TextBlock Grid.Row="2"
                                       Text="{Binding NodeRunId}"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="#697586"/>
                            <TextBlock Grid.Row="2"
                                       Grid.Column="1"
                                       Text="{Binding Role}"
                                       FontSize="12"
                                       Foreground="#697586"/>
                            <TextBlock Grid.Row="3"
                                       Text="{Binding CapabilitiesText}"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="#697586"/>
                            <TextBlock Grid.Row="3"
                                       Grid.Column="1"
                                       Text="{Binding StorageKind}"
                                       FontSize="12"
                                       Foreground="#697586"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Grid.Row="2" Spacing="4">
                <TextBlock Text="{Binding TableRefMessage}"
                           Foreground="#344054"/>
                <TextBlock Text="{Binding TableRefErrorMessage}"
                           TextWrapping="Wrap"
                           Foreground="#B42318"
                           IsVisible="{Binding HasTableRefError}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
