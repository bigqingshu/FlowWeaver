<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Avalonia_UI.ViewModels"
             x:Class="Avalonia_UI.Views.Components.Data.SharedPublicationListView"
             x:DataType="vm:MainWindowViewModel">
    <Grid RowDefinitions="2*,3*" RowSpacing="16">
        <!-- Shared Publications List -->
        <Border Classes="Card" Padding="14">
            <Grid RowDefinitions="Auto,Auto,2*,*" RowSpacing="10">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="10">
                    <TextBlock Text="{Binding ShareText}" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                    <TextBox Grid.Column="1" Text="{Binding SharedPublicationShareNameFilter}" Watermark="{Binding ShareNameWatermarkText}"/>
                    <TextBlock Grid.Column="2" Text="{Binding LimitText}" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBox Grid.Column="3" Text="{Binding SharedPublicationLimitFilter}" Watermark="100" Width="70"/>
                    <Button Grid.Column="4" Content="{Binding RefreshText}" Command="{Binding RefreshSharedPublicationsCommand}" MinWidth="84"/>
                </Grid>

                <StackPanel Grid.Row="1" Spacing="4">
                    <TextBlock Text="{Binding SharedPublicationMessage}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding SharedPublicationErrorMessage}" TextWrapping="Wrap" Foreground="{DynamicResource TextErrorBrush}" IsVisible="{Binding HasSharedPublicationError}"/>
                </StackPanel>

                <ListBox Grid.Row="2"
                         ItemsSource="{Binding SharedPublications}"
                         SelectedItem="{Binding SelectedSharedPublication}"
                         BorderBrush="{DynamicResource ControlBorderBrush}"
                         BorderThickness="1">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="vm:SharedPublicationCatalogEntryListItemViewModel"
                                      x:DataType="vm:SharedPublicationCatalogEntryListItemViewModel">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="12" Margin="8">
                                <TextBlock Text="{Binding ShareName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding LatestVersionText}" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Row="1" Text="{Binding LatestCreatedAtText}" FontSize="12" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PublishedVersionCountText}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LatestMemberCountText}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Shared Publication Versions List -->
        <Border Grid.Row="1" Classes="Card" Padding="14">
            <Grid RowDefinitions="Auto,Auto,2*,*" RowSpacing="10">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="10">
                    <TextBlock Text="{Binding VersionsText}" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                    <TextBox Grid.Column="1" Text="{Binding SharedPublicationVersionShareNameFilter}" Watermark="{Binding ShareNameWatermarkText}"/>
                    <TextBlock Grid.Column="2" Text="{Binding LimitText}" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBox Grid.Column="3" Text="{Binding SharedPublicationVersionLimitFilter}" Watermark="100" Width="70"/>
                    <Button Grid.Column="4" Content="{Binding RefreshText}" Command="{Binding RefreshSharedPublicationVersionsCommand}" MinWidth="84"/>
                </Grid>

                <StackPanel Grid.Row="1" Spacing="4">
                    <TextBlock Text="{Binding SharedPublicationVersionMessage}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding SharedPublicationVersionErrorMessage}" TextWrapping="Wrap" Foreground="{DynamicResource TextErrorBrush}" IsVisible="{Binding HasSharedPublicationVersionError}"/>
                </StackPanel>

                <ListBox Grid.Row="2"
                         ItemsSource="{Binding SharedPublicationVersions}"
                         SelectedItem="{Binding SelectedSharedPublicationVersion}"
                         BorderBrush="{DynamicResource ControlBorderBrush}"
                         BorderThickness="1">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="vm:SharedPublicationListItemViewModel"
                                      x:DataType="vm:SharedPublicationListItemViewModel">
                            <Grid RowDefinitions="Auto,Auto,Auto" Margin="8" RowSpacing="4">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <TextBlock Text="{Binding ShareName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding VersionText}" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </Grid>
                                <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <TextBlock Text="{Binding PublicationId}" FontSize="12" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding MemberCountText}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </Grid>
                                <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                    <TextBlock Text="{Binding Status}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding ExpiresAtText}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Grid Grid.Row="3" RowDefinitions="Auto,Auto,*" RowSpacing="6">
                    <Border BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="0,0,0,8"
                            IsVisible="{Binding IsSharedPublicationCleanupVisible}">
                        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="5">
                            <Grid ColumnDefinitions="*,Auto,Auto"
                                  ColumnSpacing="8">
                                <TextBlock Text="{Binding SharedCleanupTitleText}"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <Button Grid.Column="1"
                                        Content="&#x21BB;"
                                        Command="{Binding RefreshSharedPublicationCleanupPreviewCommand}"
                                        ToolTip.Tip="{Binding SharedCleanupRefreshPreviewText}"
                                        Width="28"
                                        Height="28"
                                        Padding="0"/>
                                <Button Grid.Column="2"
                                        Content="{Binding SharedCleanupActionText}"
                                        IsEnabled="{Binding CanConfirmSharedPublicationCleanup}">
                                    <Button.Flyout>
                                        <Flyout>
                                            <StackPanel Spacing="10">
                                                <TextBlock Text="{Binding SharedCleanupActionText}"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding SharedCleanupConfirmText}"
                                                           MaxWidth="320"
                                                           TextWrapping="Wrap"/>
                                                <Button Content="{Binding SharedCleanupActionText}"
                                                        Command="{Binding CleanupSharedPublicationCommand}"
                                                        Classes="Primary"
                                                        HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Flyout>
                                    </Button.Flyout>
                                </Button>
                            </Grid>
                            <Grid Grid.Row="1"
                                  ColumnDefinitions="Auto,*,Auto,*"
                                  ColumnSpacing="6">
                                <TextBlock Text="{Binding SharedCleanupStatusLabelText}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding SharedPublicationCleanupStatusText}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding SharedCleanupExpiresAtLabelText}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Grid.Column="3"
                                           Text="{Binding SharedPublicationCleanupExpiresAtText}"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </Grid>
                            <ProgressBar Grid.Row="2"
                                         IsIndeterminate="True"
                                         IsVisible="{Binding IsSharedPublicationCleanupBusy}"/>
                            <Grid Grid.Row="3" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding SharedPublicationCleanupMessage}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding SharedPublicationCleanupErrorMessage}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextErrorBrush}"
                                               IsVisible="{Binding HasSharedPublicationCleanupError}"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding SharedPublicationCleanupCountsText}"
                                           FontSize="12"
                                           VerticalAlignment="Top"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Grid>
                            <ScrollViewer Grid.Row="4"
                                          MaxHeight="64"
                                          IsVisible="{Binding HasSharedPublicationCleanupBlockers}">
                                <ItemsControl ItemsSource="{Binding SharedPublicationCleanupBlockers}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="6">
                        <ProgressBar IsIndeterminate="True"
                                     IsVisible="{Binding IsLoadingSharedPublicationVersionMembers}"/>
                        <Button Grid.Column="1"
                                Content="&#x2026;"
                                Command="{Binding LoadMoreSharedPublicationVersionMembersCommand}"
                                ToolTip.Tip="{Binding SharedMemberLoadMoreText}"
                                Width="28"
                                Height="28"
                                Padding="0"/>
                    </Grid>
                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding SelectedSharedPublicationVersionMembers}"
                             SelectedItem="{Binding SelectedSharedPublicationVersionMember}"
                             BorderBrush="{DynamicResource ControlBorderBrush}"
                             BorderThickness="1">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:SharedPublicationMemberListItemViewModel"
                                          x:DataType="vm:SharedPublicationMemberListItemViewModel">
                                <Grid ColumnDefinitions="2*,2*,Auto,Auto,Auto"
                                      ColumnSpacing="10"
                                      Margin="8,4">
                                    <TextBlock Text="{Binding ExportName}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip.Tip="{Binding ExportName}"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding LogicalTableId}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip.Tip="{Binding LogicalTableId}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding LifecycleStatusText}"
                                               ToolTip.Tip="{Binding AvailabilityText}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding VersionText}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <Button Grid.Column="4"
                                            Content="&#x2197;"
                                            Command="{Binding PreviewCommand}"
                                            ToolTip.Tip="{Binding PreviewText}"
                                            Width="28"
                                            Height="28"
                                            Padding="0"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
