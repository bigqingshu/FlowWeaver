<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Avalonia_UI.ViewModels"
             x:Class="Avalonia_UI.Views.Components.RunMonitor.RunListView"
             x:DataType="vm:MainWindowViewModel">
    <Border Classes="Card" Padding="14">
        <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" RowSpacing="10">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                <TextBlock Text="{Binding RunsSectionText}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <ProgressBar Grid.Column="1"
                             Width="88"
                             Height="8"
                             VerticalAlignment="Center"
                             IsIndeterminate="True"
                             IsVisible="{Binding IsRunBusy}"/>
                <Button Grid.Column="2"
                        Content="{Binding RefreshText}"
                        Command="{Binding RefreshRunsCommand}"
                        MinWidth="84"/>
            </Grid>

            <Grid Grid.Row="1"
                  ColumnDefinitions="*,*,*"
                  ColumnSpacing="10">
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding BackgroundRunManagement.TriggerSourceFilterText}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <ComboBox ItemsSource="{Binding BackgroundRunManagement.TriggerSourceOptions}"
                              SelectedItem="{Binding BackgroundRunManagement.SelectedTriggerSource, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="vm:BackgroundRunFilterOptionViewModel"
                                          x:DataType="vm:BackgroundRunFilterOptionViewModel">
                                <TextBlock Text="{Binding DisplayText}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Text="{Binding BackgroundRunManagement.RunModeFilterText}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <ComboBox ItemsSource="{Binding BackgroundRunManagement.RunModeOptions}"
                              SelectedItem="{Binding BackgroundRunManagement.SelectedRunMode, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="vm:BackgroundRunFilterOptionViewModel"
                                          x:DataType="vm:BackgroundRunFilterOptionViewModel">
                                <TextBlock Text="{Binding DisplayText}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
                <StackPanel Grid.Column="2" Spacing="4">
                    <TextBlock Text="{Binding BackgroundRunManagement.StatusFilterText}"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <ComboBox ItemsSource="{Binding BackgroundRunManagement.StatusOptions}"
                              SelectedItem="{Binding BackgroundRunManagement.SelectedStatus, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="vm:BackgroundRunFilterOptionViewModel"
                                          x:DataType="vm:BackgroundRunFilterOptionViewModel">
                                <TextBlock Text="{Binding DisplayText}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Grid>

            <ListBox Grid.Row="2"
                     ItemsSource="{Binding Runs}"
                     SelectedItem="{Binding SelectedRun}"
                     BorderBrush="{DynamicResource ControlBorderBrush}"
                     BorderThickness="1">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="vm:WorkflowRunListItemViewModel"
                                  x:DataType="vm:WorkflowRunListItemViewModel">
                        <Grid ColumnDefinitions="*,Auto"
                              RowDefinitions="Auto,Auto,Auto,Auto"
                              ColumnSpacing="12"
                              Margin="8">
                            <TextBlock Text="{Binding WorkflowRunId}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding StatusText}" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Row="1" Text="{Binding WorkflowText}" FontSize="12" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding StartedAtText}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Row="2" Text="{Binding TriggerSourceText}" FontSize="12" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding RunModeText}" FontSize="12" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Row="3" Text="{Binding CompletionReasonText}" FontSize="12" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding FinishedAtText}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Grid.Row="3" Spacing="8">
                <TextBlock Text="{Binding BackgroundRunManagement.PageText}"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                    <Button Content="{Binding BackgroundRunManagement.PreviousPageText}"
                            Command="{Binding BackgroundRunManagement.PreviousPageCommand}"
                            HorizontalAlignment="Stretch"/>
                    <Button Grid.Column="1"
                            Content="{Binding BackgroundRunManagement.NextPageText}"
                            Command="{Binding BackgroundRunManagement.NextPageCommand}"
                            HorizontalAlignment="Stretch"/>
                </Grid>

                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                    <Button Content="{Binding BackgroundRunManagement.RetryText}"
                            IsEnabled="{Binding BackgroundRunManagement.CanRetrySelectedRun}"
                            HorizontalAlignment="Stretch">
                        <Button.Flyout>
                            <Flyout>
                                <StackPanel Spacing="10">
                                    <TextBlock Text="{Binding BackgroundRunManagement.RetryText}"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding BackgroundRunManagement.RetryConfirmText}"
                                               MaxWidth="300"
                                               TextWrapping="Wrap"/>
                                    <Button Content="{Binding BackgroundRunManagement.RetryText}"
                                            Command="{Binding BackgroundRunManagement.RetryCommand}"
                                            Classes="Primary"
                                            HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                    <Button Grid.Column="1"
                            Content="{Binding BackgroundRunManagement.CleanupText}"
                            IsEnabled="{Binding BackgroundRunManagement.CanCleanupSelectedRun}"
                            HorizontalAlignment="Stretch">
                        <Button.Flyout>
                            <Flyout>
                                <StackPanel Spacing="10">
                                    <TextBlock Text="{Binding BackgroundRunManagement.CleanupText}"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding BackgroundRunManagement.CleanupConfirmText}"
                                               MaxWidth="300"
                                               TextWrapping="Wrap"/>
                                    <Button Content="{Binding BackgroundRunManagement.CleanupText}"
                                            Command="{Binding BackgroundRunManagement.CleanupTablesCommand}"
                                            Classes="Primary"
                                            HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                    <Panel Grid.Column="2"
                           Background="Transparent"
                           ToolTip.Tip="{Binding CancelSelectedRunDisabledReasonText}">
                        <Button Content="{Binding CancelText}"
                                IsEnabled="{Binding CanUseCancelSelectedRunAction}"
                                HorizontalAlignment="Stretch">
                            <Button.Flyout>
                                <Flyout>
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="{Binding CancelConfirmTitleText}"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding CancelConfirmMessageText}"
                                                   MaxWidth="250"
                                                   TextWrapping="Wrap"/>
                                        <Button Content="{Binding CancelText}"
                                                Command="{Binding CancelSelectedRunCommand}"
                                                Classes="Primary"
                                                HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </Panel>
                </Grid>

                <Button Content="{Binding BackgroundRunManagement.CleanupCancelText}"
                        Command="{Binding BackgroundRunManagement.CancelCleanupTablesCommand}"
                        IsVisible="{Binding BackgroundRunManagement.IsCleaningTables}"
                        HorizontalAlignment="Stretch"/>
            </StackPanel>

            <StackPanel Grid.Row="4" Spacing="4">
                <TextBlock Text="{Binding RunMessage}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding RunErrorMessage}"
                           TextWrapping="Wrap"
                           IsVisible="{Binding HasRunError}"
                           Foreground="{DynamicResource TextErrorBrush}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
