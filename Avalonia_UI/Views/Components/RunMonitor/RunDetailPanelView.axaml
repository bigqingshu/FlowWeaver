<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Avalonia_UI.ViewModels"
             xmlns:rm="using:Avalonia_UI.Views.Components.RunMonitor"
             x:Class="Avalonia_UI.Views.Components.RunMonitor.RunDetailPanelView"
             x:DataType="vm:MainWindowViewModel">
    <Border Classes="Card" Padding="14">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="12">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <TextBlock Text="{Binding RunsSectionText}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <Button Grid.Column="1"
                        Content="{Binding CurrentRunRuntimeOptionsOpenText}"
                        IsEnabled="{Binding CanOpenSelectedRunRuntimeOptions}"
                        Click="OpenRunRuntimeOptionsWindow"/>
            </Grid>
            <TextBlock Grid.Row="1" Text="{Binding RunMessage}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
            <Border Grid.Row="2"
                    Padding="8"
                    BorderBrush="{DynamicResource ControlBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    IsVisible="{Binding HasSelectedRunRuntimeOptionsSummary}">
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding RuntimeOptionsSectionText}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="{Binding SelectedRunRuntimeOptionsSummaryText}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>
            </Border>
            <ScrollViewer Grid.Row="3" IsVisible="{Binding HasRunError}" MaxHeight="180" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <Border Background="{DynamicResource ErrorBackgroundBrush}" BorderBrush="{DynamicResource ErrorBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12">
                    <TextBlock Text="{Binding RunErrorMessage}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextErrorBrush}"
                               FontFamily="Consolas"
                               FontSize="12"/>
                </Border>
            </ScrollViewer>

            <Separator Grid.Row="4"/>
            <rm:RunOverviewView Grid.Row="5" DataContext="{Binding RunOverview}"/>
            <Separator Grid.Row="6"/>
            <TextBlock Grid.Row="7" Text="{Binding NodeRunsSectionText}"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Grid.Row="8" Text="{Binding NodeRunMessage}" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
            <ScrollViewer Grid.Row="9" IsVisible="{Binding HasNodeRunError}" MaxHeight="180" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <Border Background="{DynamicResource ErrorBackgroundBrush}" BorderBrush="{DynamicResource ErrorBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12">
                    <TextBlock Text="{Binding NodeRunErrorMessage}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextErrorBrush}"
                               FontFamily="Consolas"
                               FontSize="12"/>
                </Border>
            </ScrollViewer>
        </Grid>
        </ScrollViewer>
    </Border>
</UserControl>
