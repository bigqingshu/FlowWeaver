<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Avalonia_UI.ViewModels"
             x:Class="Avalonia_UI.Views.Components.RunMonitor.RunLoopMonitorView"
             x:DataType="vm:RunLoopMonitorViewModel">
    <Border Classes="Card" Padding="14">
        <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" RowSpacing="10">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <TextBlock Text="{Binding SectionText}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <ProgressBar Grid.Column="1"
                             Width="72"
                             Height="8"
                             IsIndeterminate="True"
                             IsVisible="{Binding IsBusy}"/>
            </Grid>

            <Grid Grid.Row="1" ColumnDefinitions="88,*,Auto" ColumnSpacing="8">
                <TextBlock Text="{Binding LoopsText}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding Loops}"
                          SelectedItem="{Binding SelectedLoop, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate DataType="vm:LoopRunListItemViewModel"
                                      x:DataType="vm:LoopRunListItemViewModel">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <StackPanel>
                                    <TextBlock Text="{Binding LoopId}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding BoundaryText}"
                                               FontSize="11"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding StatusText}" FontSize="11"/>
                                    <TextBlock Text="{Binding ProgressText}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Grid.Column="2"
                        Content="{Binding LoadMoreText}"
                        Command="{Binding LoadMoreLoopsCommand}"
                        MinWidth="78"/>
            </Grid>

            <Grid Grid.Row="2" ColumnDefinitions="88,*,Auto" ColumnSpacing="8">
                <TextBlock Text="{Binding IterationsText}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding Iterations}"
                          SelectedItem="{Binding SelectedIteration, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate DataType="vm:LoopIterationListItemViewModel"
                                      x:DataType="vm:LoopIterationListItemViewModel">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                <TextBlock Text="{Binding IndexText}" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding LoopIterationId}"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding StatusText}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Grid>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Grid.Column="2"
                        Content="{Binding LoadMoreText}"
                        Command="{Binding LoadMoreIterationsCommand}"
                        MinWidth="78"/>
            </Grid>

            <TabControl Grid.Row="3">
                <TabItem Header="{Binding LoopDetailsText}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="8" Spacing="10">
                            <TextBlock Text="{Binding SelectLoopText}"
                                       IsVisible="{Binding !HasSelectedLoop}"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <StackPanel IsVisible="{Binding HasSelectedLoop}" Spacing="10">
                                <Grid ColumnDefinitions="Auto,*"
                                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                                      ColumnSpacing="12"
                                      RowSpacing="6">
                                    <TextBlock Text="{Binding LoopRunIdLabel}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SelectedLoop.LoopRunId}" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Row="1" Text="{Binding LoopIdLabel}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedLoop.LoopId}" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Row="2" Text="{Binding StartNodeLabel}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedLoop.StartNodeInstanceId}" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Row="3" Text="{Binding JudgeNodeLabel}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedLoop.JudgeNodeInstanceId}" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Row="4" Text="{Binding StatusLabel}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedLoop.StatusText}"/>
                                    <TextBlock Grid.Row="5" Text="{Binding ProgressLabel}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedLoop.ProgressText}"/>
                                    <TextBlock Grid.Row="6" Text="{Binding ExitReasonLabel}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SelectedLoop.ExitReasonText}" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Row="7" Text="{Binding StartedLabel}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding SelectedLoop.StartedAtText}"/>
                                    <TextBlock Grid.Row="8" Text="{Binding FinishedLabel}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding SelectedLoop.FinishedAtText}"/>
                                    <TextBlock Grid.Row="9" Text="{Binding DurationLabel}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding SelectedLoop.DurationText}"/>
                                </Grid>
                                <Border IsVisible="{Binding SelectedLoop.HasError}"
                                        Background="{DynamicResource ErrorBackgroundBrush}"
                                        BorderBrush="{DynamicResource ErrorBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="10">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="{Binding ErrorText}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding SelectedLoop.ErrorJson}"
                                                   TextWrapping="Wrap"
                                                   FontFamily="Consolas"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextErrorBrush}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="{Binding IterationDetailsText}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="8" Spacing="10">
                            <TextBlock Text="{Binding SelectIterationText}"
                                       IsVisible="{Binding !HasSelectedIteration}"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                            <StackPanel IsVisible="{Binding HasSelectedIteration}" Spacing="10">
                                <Grid ColumnDefinitions="Auto,*"
                                      RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                                      ColumnSpacing="12"
                                      RowSpacing="6">
                                    <TextBlock Text="{Binding IterationIdLabel}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SelectedIteration.LoopIterationId}" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Row="1" Text="{Binding IterationIndexLabel}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedIteration.IndexText}"/>
                                    <TextBlock Grid.Row="2" Text="{Binding StatusLabel}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedIteration.StatusText}"/>
                                    <TextBlock Grid.Row="3" Text="{Binding InputTableRefLabel}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedIteration.InputTableRefIdText}" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Row="4" Text="{Binding OutputTableRefLabel}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedIteration.OutputTableRefIdText}" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Row="5" Text="{Binding FailedNodeRunLabel}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedIteration.FailedNodeRunIdText}" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Row="6" Text="{Binding StartedLabel}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding SelectedIteration.StartedAtText}"/>
                                    <TextBlock Grid.Row="7" Text="{Binding FinishedLabel}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding SelectedIteration.FinishedAtText}"/>
                                    <TextBlock Grid.Row="8" Text="{Binding DurationLabel}" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding SelectedIteration.DurationText}"/>
                                </Grid>
                                <Border IsVisible="{Binding SelectedIteration.HasError}"
                                        Background="{DynamicResource ErrorBackgroundBrush}"
                                        BorderBrush="{DynamicResource ErrorBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="10">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="{Binding ErrorText}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding SelectedIteration.ErrorJson}"
                                                   TextWrapping="Wrap"
                                                   FontFamily="Consolas"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextErrorBrush}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="{Binding NodesText}">
                    <ListBox ItemsSource="{Binding IterationNodes}"
                             MinHeight="180">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:LoopIterationNodeListItemViewModel"
                                          x:DataType="vm:LoopIterationNodeListItemViewModel">
                                <Expander Margin="8"
                                          Header="{Binding HeaderText}"
                                          HorizontalContentAlignment="Stretch">
                                    <StackPanel Margin="0,8,0,0" Spacing="8">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <TextBlock Text="{Binding StatusText}"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding ProgressText}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </Grid>
                                        <TextBlock Text="{Binding DiagnosticText}"
                                                   TextWrapping="Wrap"
                                                   FontFamily="Consolas"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <Border IsVisible="{Binding HasError}"
                                                Background="{DynamicResource ErrorBackgroundBrush}"
                                                BorderBrush="{DynamicResource ErrorBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Padding="8">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding ErrorText}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding ErrorJson}"
                                                           TextWrapping="Wrap"
                                                           FontFamily="Consolas"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource TextErrorBrush}"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Expander>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </TabItem>
                <TabItem Header="{Binding TablesText}">
                    <ListBox ItemsSource="{Binding IterationTableRefs}"
                             MinHeight="180">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:LoopIterationTableRefListItemViewModel"
                                          x:DataType="vm:LoopIterationTableRefListItemViewModel">
                                <Grid Margin="8"
                                      ColumnDefinitions="*,Auto"
                                      RowDefinitions="Auto,Auto"
                                      ColumnSpacing="8">
                                    <TextBlock Text="{Binding LogicalTableId}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Role}"/>
                                    <TextBlock Grid.Row="1"
                                               Text="{Binding SourceText}"
                                               FontSize="11"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="1"
                                               Text="{Binding LifecycleStatus}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </TabItem>
            </TabControl>

            <StackPanel Grid.Row="4" Spacing="4">
                <TextBlock Text="{Binding Message}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding ErrorMessage}"
                           IsVisible="{Binding HasError}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextErrorBrush}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
